{
  "name": "react-muscle-map",
  "version": "0.1.0",
  "description": "Themeable React muscle maps and packaged datasets for free-exercise-db.",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Josep1992/react-muscle-map.git"
  },
  "homepage": "https://github.com/Josep1992/react-muscle-map#readme",
  "bugs": {
    "url": "https://github.com/Josep1992/react-muscle-map/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "exercise",
    "fitness",
    "muscle-map",
    "svg",
    "free-exercise-db"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./types/index.d.ts",
  "files": [
    "dist/",
    "datasets/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./styles.css": "./dist/esm/styles.css",
    "./exercises/*": {
      "types": "./types/exercise-component.d.ts",
      "import": "./dist/esm/exercises/*.js",
      "require": "./dist/cjs/exercises/*.cjs"
    },
    "./datasets/exercises.json": "./datasets/exercises.json",
    "./datasets/exercises/*": "./datasets/exercises/*.json",
    "./datasets/manifest.json": "./datasets/manifest.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "generate": "node scripts/generate-muscle-map-components.mjs --all --chunk-size 50",
    "check:generated": "node scripts/generate-muscle-map-components.mjs --all --chunk-size 50 --check",
    "test": "node muscleMap.test.mjs",
    "typecheck": "tsc --project type-tests/tsconfig.json",
    "prepack": "npm run check:generated && npm test && npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "3.1.0",
    "@types/react": "18.3.12",
    "react": "18.3.1",
    "typescript": "5.4.5",
    "vite": "4.5.14"
  }
}
